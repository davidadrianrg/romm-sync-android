# ── keystore.properties (TEMPLATE) ─────────────────────────────────────
# Copia este archivo a keystore.properties (en la raíz del proyecto) y
# rellena con los datos de tu keystore de release.
#
#   cp keystore.properties.example keystore.properties
#
# ⚠️  NO commitear keystore.properties — está en .gitignore.
#
# Generar un keystore nuevo:
#   keytool -genkeypair -alias romm-sync -keyalg RSA -keysize 2048 \
#     -validity 10000 -keystore romm-sync.jks \
#     -storepass TU_PASSWORD -keypass TU_PASSWORD \
#     -dname "CN=RomM Sync, OU=Dev, O=davidrg, L=Madrid, ST=Madrid, C=ES"

storeFile=romm-sync.jks
storePassword=TU_STORE_PASSWORD
keyAlias=romm-sync
keyPassword=TU_KEY_PASSWORD
